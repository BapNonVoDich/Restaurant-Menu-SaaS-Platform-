<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.24.xsd">

    <changeSet id="010-store-table-domain" author="saas">
        <addColumn tableName="stores">
            <column name="table_ordering_enabled" type="boolean" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
            <column name="custom_domain" type="varchar(255)"/>
            <column name="domain_verified" type="boolean" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
            <column name="domain_verification_token" type="varchar(64)"/>
        </addColumn>
        <addUniqueConstraint tableName="stores" columnNames="custom_domain" constraintName="uk_stores_custom_domain"/>
    </changeSet>
</databaseChangeLog>
