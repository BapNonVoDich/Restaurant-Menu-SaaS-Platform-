<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
    http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.24.xsd">

    <changeSet id="005-add-menu-file-url-field" author="restaurant-saas">
        <addColumn tableName="stores">
            <column name="menu_file_url" type="VARCHAR(500)">
                <constraints nullable="true"/>
            </column>
        </addColumn>
        <comment>Add menu_file_url field to store uploaded menu file (image/PDF) URL</comment>
    </changeSet>

</databaseChangeLog>
