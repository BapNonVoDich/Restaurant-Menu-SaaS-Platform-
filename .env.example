# Copy to .env in the repo root and adjust for your environment.
# Docker Compose substitutes these into service environment blocks.

# --- Shared / security ---
JWT_SECRET=change-me-to-a-long-random-secret-min-256-bits
JWT_EXPIRATION=86400000

# Gateway CORS (comma-separated origins)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Internal catalog ↔ payment subscription sync (must match catalog + payment config)
INTERNAL_SUBSCRIPTION_KEY=dev-internal-subscription-key-change-me

# --- Catalog: image uploads (optional) ---
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# --- VNPay (payment service) ---
VNPAY_RETURN_URL=http://localhost:3000/payment/return
VNPAY_IPN_URL=http://localhost:8084/vnpay/ipn
